# Database — SQLite file path (shared between web and worker via Docker volume)
DATABASE_URL="file:./data/backlink.db"

# Worker concurrency settings (optional, these are defaults)
WORKER_CRAWL_CONCURRENCY=3
WORKER_DOMAIN_CHECK_CONCURRENCY=10
WORKER_POLL_INTERVAL_MS=2000

# Crawler settings (optional)
CRAWLER_MAX_DEPTH=5
CRAWLER_MAX_PAGES_PER_SITE=500
CRAWLER_PAGE_CONCURRENCY=5
CRAWLER_REQUEST_TIMEOUT_MS=15000
CRAWLER_RATE_LIMIT_MS=500

# Optional: OpenPageRank API for DA metrics (leave empty to skip)
# Get free key at: https://www.domcop.com/openpagerank/
OPENPAGERANK_API_KEY=

# Next.js
NEXTAUTH_SECRET=change-me-in-production
NODE_ENV=development
